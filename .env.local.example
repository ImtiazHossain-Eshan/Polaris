# Get a free key at https://aistudio.google.com/apikey
# (Generous free tier — no card required.)
# Without this set, Polaris falls back to the deterministic heuristic engine
# so the demo flow still works end-to-end.
GEMINI_API_KEY=

# MongoDB connection string
# Free tier at https://www.mongodb.com/atlas — create a cluster,
# then get the connection string from Database > Connect > Drivers.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ─── LemonSqueezy (subscriptions) ───
# 1. Create a store at https://app.lemonsqueezy.com (test mode is fine).
# 2. Create two subscription products: "Polaris Pro" and "Polaris Elite".
# 3. Copy each product's VARIANT id (Products > variant > ... > Copy ID).
# 4. Create an API key under Settings > API.
# 5. Add a webhook (Settings > Webhooks) pointing to
#    <your-domain>/api/webhooks/lemonsqueezy, subscribe to all subscription_*
#    events, and copy the signing secret.
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_WEBHOOK_SECRET=
LEMONSQUEEZY_VARIANT_PRO=
LEMONSQUEEZY_VARIANT_ELITE=
