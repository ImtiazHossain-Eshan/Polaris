# Get a free key at https://aistudio.google.com/apikey
# (Generous free tier — no card required.)
# Without this set, Polaris falls back to the deterministic heuristic engine
# so the demo flow still works end-to-end.
GEMINI_API_KEY=

# MongoDB connection string
# Free tier at https://www.mongodb.com/atlas — create a cluster,
# then get the connection string from Database > Connect > Drivers.
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
